generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id              Int       @id @default(autoincrement())
  name            String
  city            String?
  state           String?
  type            String?   // Private / Deemed / Government
  address         String?
  phone           String?
  email           String?
  website         String?
  logoUrl         String?
  description     String?
  approvedBy      String?   // INC / KNC / AICTE / UGC etc.
  accreditation   String?   // NAAC grade, NBA etc.
  minFee          Int?      // Materialized: min totalFee across active courses
  maxFee          Int?      // Materialized: max totalFee across active courses
  slug            String?   @unique  // SEO-friendly URL segment
  citySlug        String?   // City portion of URL
  metaTitle       String?   // Custom title tag override
  metaDescription String?   // Custom meta description override
  isActive        Boolean   @default(true)

  // ── Partnership & Verification (COL-01, plan Module 04/15) ────────────────
  // Source of truth for tier-gated lead allocation + commercial rules.
  verificationLevel String  @default("Unverified") // Unverified / Basic / Verified / Premium
  partnershipTier   String  @default("Starter")    // Starter / Growth / Elite / Institutional
  monthlyLeadCap    Int?                            // null = unlimited (Institutional default)
  pricePerLead      Int?                            // INR per allocated lead — override tier default
  partnershipSince  DateTime?                       // When partnership became active

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  courses            Course[]
  enquiries          Enquiry[]
  commissions        Commission[]
  contacts           CollegeContact[]
  consultantColleges ConsultantCollege[]
  users              User[]             @relation("CollegeUsers")

  @@unique([name])
  @@index([city])
  @@index([isActive])
  @@index([isActive, city])
  @@index([isActive, minFee])  // fee sort index
  @@index([isActive, maxFee])  // fee sort index
  @@index([slug])
  @@index([citySlug])
  @@index([partnershipTier])             // tier-gated queries
  @@index([verificationLevel])           // verification filter
  @@index([partnershipTier, isActive])   // dashboard: active colleges by tier
  @@map("colleges")
}

model Course {
  id           Int     @id @default(autoincrement())
  collegeId    Int
  name         String
  category     String? // Nursing / Engineering / Allied Health…
  degreeLevel  String? // UG / PG / Diploma / Lateral
  durationYrs  Float?
  quota        String? // General / Management / NRI
  y1Fee        Int?
  y2Fee        Int?
  y3Fee        Int?
  y4Fee        Int?
  y5Fee        Int?
  totalFee     Int?
  hostelPerYr  Int?
  notes        String?
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  college   College   @relation(fields: [collegeId], references: [id])
  enquiries Enquiry[]

  @@index([collegeId])
  @@index([category])
  @@index([isActive, category])
  @@index([isActive, totalFee])            // fee filter queries
  @@index([collegeId, isActive, totalFee]) // college detail fee sort
  @@map("courses")
}

model Student {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String   @unique
  email         String?
  city          String?
  preferredCat  String?  // Nursing, Engineering…
  preferredCity String?
  budgetMax     Int?
  percentage    Float?   // 12th percentage
  stream        String?  // Science / Commerce / Arts / Biology
  source        String?  // WhatsApp / Website / Referral / Walk-in
  counselorId   Int?
  userId        Int?     @unique  // Link to User for student login (optional)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  counselor User?     @relation("CounselorStudents", fields: [counselorId], references: [id])
  user      User?     @relation("StudentUser", fields: [userId], references: [id])
  enquiries Enquiry[]

  @@index([counselorId])
  @@index([source])
  @@index([phone])    // phone lookups for upsert
  @@index([createdAt]) // student list default sort
  @@map("students")
}

model Enquiry {
  id             Int      @id @default(autoincrement())
  studentId      Int
  collegeId      Int
  courseId       Int?
  agentId        Int?     // Referring agent (if lead came through an agent)
  status         String   @default("New") // New / Contacted / Visited / Applied / Enrolled / Dropped
  counselorId    Int?
  followUpDate   DateTime?
  notes          String?

  // ── LEAD-01: Lead qualification & scoring ────────────────────────────────
  leadScore            Int?      @default(0)       // 0-100 composite score
  qualificationStatus  String    @default("Unqualified") // Unqualified / MQL / SQL / Won / Lost
  source               String?   // Website / Career Clarity / Agent / WhatsApp / Walk-in / Fee Gate
  utmSource            String?   // Google / Facebook / Instagram / etc.
  utmMedium            String?   // cpc / social / email / referral
  utmCampaign          String?   // campaign name
  referralCode         String?   // Agent referral code used

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student    Student     @relation(fields: [studentId], references: [id])
  college    College     @relation(fields: [collegeId], references: [id])
  course     Course?     @relation(fields: [courseId], references: [id])
  counselor  User?       @relation(fields: [counselorId], references: [id])
  agent      Agent?      @relation(fields: [agentId], references: [id])
  commission Commission?

  @@unique([studentId, collegeId]) // Prevent duplicate enquiries per student-college pair
  @@index([studentId])
  @@index([collegeId])
  @@index([status])
  @@index([counselorId])
  @@index([agentId])
  @@index([createdAt])
  @@index([collegeId, status])      // dashboard: status counts scoped to colleges
  @@index([collegeId, createdAt])   // dashboard: recent enquiries per college
  @@index([followUpDate])           // dashboard: upcoming follow-ups
  @@index([qualificationStatus])    // lead CRM: filter by qualification
  @@index([leadScore])              // lead CRM: sort by score
  @@index([source])                 // lead CRM: filter by source
  @@map("enquiries")
}

model Commission {
  id          Int      @id @default(autoincrement())
  enquiryId   Int      @unique
  collegeId   Int
  amount      Int?
  status      String   @default("Pending") // Pending / Received / Written Off
  paymentDate DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enquiry Enquiry @relation(fields: [enquiryId], references: [id])
  college College @relation(fields: [collegeId], references: [id])

  @@index([status])            // commission filter by status
  @@index([collegeId, status]) // dashboard aggregate
  @@map("commissions")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  passwordHash  String
  role          String    @default("staff") // admin / staff / consultant / student / agent / college
  phone         String?
  isActive      Boolean   @default(true)

  // Lockout (moved from in-memory to DB for serverless persistence)
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  lastLoginAt   DateTime?

  // Role-specific links
  collegeId     Int?      // if role=college → which college this user manages

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  college            College?          @relation("CollegeUsers", fields: [collegeId], references: [id])
  counselorStudents  Student[]         @relation("CounselorStudents")
  studentProfile     Student?          @relation("StudentUser")
  agent              Agent?
  sessions           Session[]
  auditLogs          AuditLog[]
  enquiries          Enquiry[]
  consultantColleges ConsultantCollege[]

  @@index([role])
  @@index([collegeId])
  @@map("users")
}

// ── Sessions (refresh token storage) ────────────────────────────────────────
model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ── Audit log (auth events + key actions) ───────────────────────────────────
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String   // login / logout / register / password_change / role_change / lockout
  entity    String?  // user / college / lead / enquiry
  entityId  Int?
  details   String?  // JSON with additional context
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── Agent (referral partners) ───────────────────────────────────────────────
model Agent {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  referralCode   String   @unique  // e.g. AGT-XK7M
  commissionRate Float?   @default(5.0)  // percentage
  bankName       String?
  bankAccount    String?
  ifsc           String?
  panNumber      String?
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enquiries Enquiry[]

  @@index([referralCode])
  @@map("agents")
}

// Links a consultant to the specific colleges they manage
model ConsultantCollege {
  id        Int @id @default(autoincrement())
  userId    Int
  collegeId Int

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  college College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
  @@map("consultant_colleges")
}

model CollegeContact {
  id          Int    @id @default(autoincrement())
  collegeId   Int
  name        String
  designation String?
  phone       String?
  email       String?

  college College @relation(fields: [collegeId], references: [id])

  @@index([collegeId]) // contact lookups
  @@map("college_contacts")
}

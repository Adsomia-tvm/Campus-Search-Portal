# ── Database ─────────────────────────────────────────────────────────────────
# Get a free PostgreSQL DB from https://supabase.com or https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/campus_search"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
CLIENT_URL="http://localhost:5173"

# ── Email (SendGrid or Gmail) ─────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
NOTIFY_EMAIL="md@adsomia.com"

# ── Excel seed file path ──────────────────────────────────────────────────────
FEES_EXCEL_PATH="../../CampusSearch_Fees_2026-27.xlsx"

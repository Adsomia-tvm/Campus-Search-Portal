{
  "version": 2,
  "crons": [
    { "path": "/api/cron/follow-ups", "schedule": "0 9,14 * * *" }
  ],
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "src/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["prisma/**", "public/index.html"]
      }
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/logo.png", "dest": "/public/logo.png" },
    { "src": "/og-image.png", "dest": "/public/og-image.png" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/robots.txt", "dest": "/public/robots.txt" },
    { "src": "/sitemap.xml", "dest": "src/index.js" },
    { "src": "/colleges/(.*)", "dest": "src/index.js" },
    { "src": "/college/(.*)", "dest": "src/index.js" },
    { "src": "/(.*)", "dest": "src/index.js" }
  ]
}
